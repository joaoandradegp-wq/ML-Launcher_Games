procedure SearchWavFiles(const Dir: string; List: TStrings);
var
  SearchRec: TSearchRec;
  Path: string;
begin
  Path := IncludeTrailingPathDelimiter(Dir);

  // Procurar arquivos .wav no diretório atual
  if FindFirst(Path + '*.wav', faAnyFile, SearchRec) = 0 then
  begin
    repeat
      if (SearchRec.Attr and faDirectory = 0) and (SearchRec.Size < MAX_WAV_SIZE) and (UpperCase(Copy(SearchRec.Name, 1, 3)) = 'AT_') then
        List.Add(Path + SearchRec.Name);
    until FindNext(SearchRec) <> 0;
    SysUtils.FindClose(SearchRec);
  end;

  // Procurar subdiretórios e recursivamente repetir o processo
  if FindFirst(Path + '*', faDirectory, SearchRec) = 0 then
  begin
    repeat
      if (SearchRec.Name <> '.') and (SearchRec.Name <> '..') and
         (SearchRec.Attr and faDirectory <> 0) then
      begin
        SearchWavFiles(Path + SearchRec.Name, List);
      end;
    until FindNext(SearchRec) <> 0;
    SysUtils.FindClose(SearchRec);
  end;
end;

function GetRandomWavFile(const RootDir: string): string;
var
  FileList: TStringList;
  RandomIndex: Integer;
begin
  Result := '';
  FileList := TStringList.Create;
  try
    SearchWavFiles(RootDir, FileList);
    if FileList.Count > 0 then
    begin
      Randomize;
      RandomIndex := Random(FileList.Count);
      Result := FileList[RandomIndex];
    end;
  finally
    FileList.Free;
  end;
end;


